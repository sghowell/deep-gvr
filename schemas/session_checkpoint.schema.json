{
  "type": "object",
  "required": [
    "session_id",
    "problem",
    "domain",
    "started",
    "last_updated",
    "status",
    "current_iteration",
    "max_iterations",
    "next_phase",
    "active_branch_id",
    "branches",
    "literature_context",
    "candidate",
    "verification_report",
    "verdict_history",
    "result_summary",
    "final_verdict",
    "evidence_file",
    "artifacts_dir",
    "memory_summary_file",
    "parallax_manifest_file",
    "formal_lifecycle",
    "artifacts"
  ],
  "additionalProperties": false,
  "properties": {
    "session_id": { "type": "string", "minLength": 1 },
    "problem": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "started": { "type": "string", "minLength": 1 },
    "last_updated": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "current_iteration": { "type": "integer" },
    "max_iterations": { "type": "integer" },
    "next_phase": { "type": "string", "minLength": 1 },
    "active_branch_id": { "type": "string", "minLength": 1 },
    "branches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "branch_id",
          "strategy",
          "status",
          "rationale",
          "parent_branch_id",
          "created_iteration",
          "activated_iteration",
          "closed_iteration",
          "failure_count"
        ],
        "additionalProperties": false,
        "properties": {
          "branch_id": { "type": "string", "minLength": 1 },
          "strategy": {
            "type": "string",
            "enum": ["primary", "alternative_approach", "decomposition"]
          },
          "status": {
            "type": "string",
            "enum": ["active", "queued", "completed", "failed", "abandoned"]
          },
          "rationale": { "type": "string", "minLength": 1 },
          "parent_branch_id": { "type": ["string", "null"] },
          "created_iteration": { "type": "integer" },
          "activated_iteration": { "type": ["integer", "null"] },
          "closed_iteration": { "type": ["integer", "null"] },
          "failure_count": { "type": "integer" }
        }
      }
    },
    "literature_context": { "type": "array", "items": { "type": "string" } },
    "candidate": { "type": ["object", "null"] },
    "verification_report": { "type": ["object", "null"] },
    "verdict_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["iteration", "verdict", "flaws"],
        "additionalProperties": false,
        "properties": {
          "iteration": { "type": "integer" },
          "verdict": { "type": "string", "enum": ["VERIFIED", "FLAWS_FOUND", "CANNOT_VERIFY"] },
          "flaws": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "result_summary": { "type": "string" },
    "final_verdict": { "type": "string", "minLength": 1 },
    "evidence_file": { "type": "string", "minLength": 1 },
    "artifacts_dir": { "type": "string", "minLength": 1 },
    "memory_summary_file": { "type": "string", "minLength": 1 },
    "parallax_manifest_file": { "type": "string", "minLength": 1 },
    "formal_lifecycle": {
      "type": ["object", "null"],
      "required": ["backend", "transport", "proof_status", "handles", "last_transition", "details"],
      "additionalProperties": false,
      "properties": {
        "backend": { "type": "string", "minLength": 1 },
        "transport": { "type": "string", "minLength": 1 },
        "proof_status": {
          "type": "string",
          "enum": ["requested", "pending", "proved", "disproved", "timeout", "error", "unavailable"]
        },
        "handles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "claim",
              "backend",
              "project_id",
              "transport",
              "proof_status",
              "submitted_at",
              "last_polled_at",
              "poll_count",
              "details"
            ],
            "additionalProperties": false,
            "properties": {
              "claim": { "type": "string", "minLength": 1 },
              "backend": { "type": "string", "minLength": 1 },
              "project_id": { "type": "string", "minLength": 1 },
              "transport": { "type": "string", "minLength": 1 },
              "proof_status": {
                "type": "string",
                "enum": ["requested", "pending", "proved", "disproved", "timeout", "error", "unavailable"]
              },
              "submitted_at": { "type": "string", "minLength": 1 },
              "last_polled_at": { "type": ["string", "null"] },
              "poll_count": { "type": "integer" },
              "details": { "type": "string" }
            }
          }
        },
        "last_transition": { "type": "string", "minLength": 1 },
        "details": { "type": "string" }
      }
    },
    "artifacts": { "type": "array", "items": { "type": "string" } }
  }
}
