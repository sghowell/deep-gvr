{
  "type": "object",
  "required": [
    "mode",
    "run_id",
    "runner_backend",
    "output_root",
    "enabled_tiers",
    "generated_at",
    "suite_path",
    "routing_probe_status",
    "cases",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "mode": { "type": "string", "enum": ["deterministic", "live"] },
    "run_id": { "type": "string", "minLength": 1 },
    "runner_backend": { "type": "string", "enum": ["fixture", "hermes_chat"] },
    "output_root": { "type": "string", "minLength": 1 },
    "enabled_tiers": {
      "type": "array",
      "items": { "type": "integer", "enum": [1, 2, 3] },
      "minItems": 1
    },
    "generated_at": { "type": "string", "minLength": 1 },
    "suite_path": { "type": "string", "minLength": 1 },
    "routing_probe_status": { "type": "string", "enum": ["ready", "fallback", "blocked"] },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "mode",
          "id",
          "category",
          "scenario",
          "expected_verdict",
          "actual_verdict",
          "expected_tiers",
          "actual_tiers",
          "iterations",
          "passed",
          "strict_verdict_match",
          "verdict_accepted",
          "tiers_matched_expected",
          "accepted_refutation",
          "outcome",
          "routing_mode",
          "provider",
          "model_used",
          "session_id",
          "artifacts",
          "runtime_seconds",
          "error",
          "notes"
        ],
        "additionalProperties": false,
        "properties": {
          "mode": { "type": "string", "enum": ["deterministic", "live"] },
          "id": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "minLength": 1 },
          "scenario": { "type": "string", "minLength": 1 },
          "expected_verdict": { "type": "string", "enum": ["VERIFIED", "FLAWS_FOUND", "CANNOT_VERIFY"] },
          "actual_verdict": { "type": "string", "enum": ["VERIFIED", "FLAWS_FOUND", "CANNOT_VERIFY"] },
          "expected_tiers": { "type": "array", "items": { "type": "integer", "enum": [1, 2, 3] } },
          "actual_tiers": { "type": "array", "items": { "type": "integer", "enum": [1, 2, 3] } },
          "iterations": { "type": "integer", "minimum": 0 },
          "passed": { "type": "boolean" },
          "strict_verdict_match": { "type": "boolean" },
          "verdict_accepted": { "type": "boolean" },
          "tiers_matched_expected": { "type": "boolean" },
          "accepted_refutation": { "type": "boolean" },
          "outcome": {
            "type": "string",
            "enum": [
              "direct_match",
              "accepted_refutation",
              "tier_mismatch",
              "verdict_mismatch",
              "execution_error"
            ]
          },
          "routing_mode": { "type": "string", "enum": ["direct", "temperature_decorrelation"] },
          "provider": { "type": "string" },
          "model_used": { "type": "string" },
          "session_id": { "type": "string", "minLength": 1 },
          "artifacts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "runtime_seconds": { "type": "number", "minimum": 0 },
          "error": { "type": ["string", "null"] },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total_cases",
        "passed_cases",
        "failed_cases",
        "verdict_match_rate",
        "true_positive_rate",
        "true_negative_rate",
        "false_positive_rate",
        "tier_accuracy",
        "iteration_efficiency",
        "failure_admission_rate",
        "meets_false_positive_bar",
        "direct_match_cases",
        "accepted_refutation_cases",
        "tier_mismatch_failures",
        "verdict_mismatch_failures",
        "execution_error_failures"
      ],
      "additionalProperties": false,
      "properties": {
        "total_cases": { "type": "integer", "minimum": 0 },
        "passed_cases": { "type": "integer", "minimum": 0 },
        "failed_cases": { "type": "integer", "minimum": 0 },
        "verdict_match_rate": { "type": "number" },
        "true_positive_rate": { "type": "number" },
        "true_negative_rate": { "type": "number" },
        "false_positive_rate": { "type": "number" },
        "tier_accuracy": { "type": "number" },
        "iteration_efficiency": { "type": "number" },
        "failure_admission_rate": { "type": "number" },
        "meets_false_positive_bar": { "type": "boolean" },
        "direct_match_cases": { "type": "integer", "minimum": 0 },
        "accepted_refutation_cases": { "type": "integer", "minimum": 0 },
        "tier_mismatch_failures": { "type": "integer", "minimum": 0 },
        "verdict_mismatch_failures": { "type": "integer", "minimum": 0 },
        "execution_error_failures": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
